	// ========================
	// Bookmarks Extension Settings
	// ========================
	// Allows navigation through all files that contain bookmarks.
	"bookmarks.navigateThroughAllFiles": true,
	// Allows navigation to wrap around at the first and last bookmarks in scope.
	"bookmarks.wrapNavigation": true,
	// If set to true, bookmarks are saved in the project, which is useful for version control.
	"bookmarks.saveBookmarksInProject": false,
	// Path to another image to be shown as a bookmark icon (16x16 px).
	// "bookmarks.gutterIconPath": "",
	// Enables bookmarks commands to be displayed on the editor context menu.
	"bookmarks.showCommandsInContextMenu": true,
	// Enables the new Sticky engine for improved source change detections and undo operations.
	"bookmarks.experimental.enableNewStickyEngine": true,
	// If a line with a bookmark is deleted, this keeps the bookmark on the next available line.
	"bookmarks.keepBookmarksOnLineDelete": false,
	// Workaround for formatters (like Prettier) that break the Sticky engine.
	// Can be turned off if `experimental.enableNewStickyEngine` is true.
	"bookmarks.useWorkaroundForFormatters": false,
	// Controls if the Bookmarks side bar should start expanded.
	"bookmarks.sideBar.expanded": false,
	// Controls the count badge on the Bookmark icon in the Activity Bar.
	// `all` shows the total count, `files` shows the number of files with bookmarks.
	"bookmarks.sideBar.countBadge": "all",
	// Controls how multi-cursor toggles handle bookmarked lines.
	"bookmarks.multicursor.toggleMode": "allLinesAtOnce",
	// Controls how labels are suggested when creating bookmarks.
	"bookmarks.label.suggestion": "dontUse",
	// Controls the location where the editor reveals a bookmarked line.
	//
	// HIGHLIGHT EXTENSION
	"highlight.regexes": {
		// Highlight every instance of "A." (e.g., A.my_static_method)
		"\\b(A\\.)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#FFEEA1E5",
					// "fontWeight": "bold"
				}
			]
		},
		"\\b(SEA\\.)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#FFEEA1E5",
					// "fontWeight": "bold"
				}
			]
		},
		// Highlight the action names that follow "InAction."
		"(RawAction\\.)(\\w+)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#FFEEA1E5"
				}, // This applies a subtle color to the "InAction." part
				{
					// "color": "#FFEEA1E5",
				} // This applies the yellow color to the word
			]
		},
		"(PS\\.)(\\w+)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#5da9ff"
				}, // This applies a subtle color to the "InAction." part
				{
					// "color": "#FFEEA1E5",
				} // This applies the yellow color to the word
			]
		},
		"(LS\\.)(\\w+)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#f3c56ff3"
				}, // This applies a subtle color to the "InAction." part
				{
					// "color": "#FFEEA1E5",
				} // This applies the yellow color to the word
			]
		},
		"(PlayerState\\.)(\\w+)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#5da9ff"
				}, // This applies a subtle color to the "InAction." part
				{
					// "color": "#FFEEA1E5",
				} // This applies the yellow color to the word
			]
		},
		"(SEState\\.)(\\w+)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#5da9ff"
				}, // This applies a subtle color to the "InAction." part
				{
					// "color": "#FFEEA1E5",
				} // This applies the yellow color to the word
			]
		},
		"(traits)(\\.)(\\w+)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#d1d1d1d7",
					"fontWeight": "bold",
					"textDecoration": "underline"
				},
				{
					// "color": "#FFEEA1E5",
				} // This applies the yellow color to the word
			]
		},
		"\\b(print_\\.)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#A3A3F5",
				}
			]
		}
	}
