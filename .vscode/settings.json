	/* EXAMPLES 1 (CHECK FOR SANITY)
	"highlight.regexes": {
		// EXAMPLES
		// 1. Highlight the '_run' and '_cleanup' functions to make them stand out.
		//    We use a regex to match the function definition and give it a background color.
		"^(func)( )(_run|_cleanup)": {
			"regexFlags": "gm",
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "white",
					"backgroundColor": "#FF5733"
				}, // 'func' keyword
				{}, // space
				{
					"backgroundColor": "#FF5733",
