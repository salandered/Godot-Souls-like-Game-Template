	"godotTools.editorPath.godot4": "c:\\safe\\godot\\Godot_v4.4.1-stable_win64.exe\\Godot_v4.4.1-stable_win64.exe",
	// exlude from file view
	"files.exclude": {
		// godot 
		// "**/*.res": true,
		"**/*.gd.uid": true,
		// images
		"**/*.jpg": true,
		"**/*.png": true,
		"**/*.png.import": true,
		"**/*.jpg.import": true,
		"**/*.svg.import": true,
		"**/*.tmp": true,
		"**/*.TMP": true,
	},
	// dont open file again in split view
	"workbench.editor.revealIfOpen": true,
	//
	// FIGHTING COPILOT
	// Only show code actions on non-empty lines (the old behaviour of code actions): "editor.lightbulb.enabled": "onCode"
	"github.copilot.editor.enableCodeActions": false, // no yellow stars
	"editor.inlineSuggest.enabled": true,
	//
	// Code completions settings
	// "github.copilot.enable": true,
	"editor.inlineSuggest.syntaxHighlightingEnabled": false,
	//
	// NES settings
	"github.copilot.nextEditSuggestions.enabled": true,
	"editor.inlineSuggest.edits.allowCodeShifting": "never",
	"editor.inlineSuggest.edits.renderSideBySide": "never", // show inline suggestions in the same line
	// "editor.inlineSuggest.edits.showCollapsed": true, // can be configured from UI button
	// 
	// Suggestions (not copilot)
	"editor.suggestSelection": "recentlyUsed",
	"editor.inlineSuggest.showToolbar": "never", // listed in copilot Code completions settings
