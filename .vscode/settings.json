	//
	// COLORS
	"workbench.colorCustomizations": {
		// BUILD IN
		"editor.findMatchBackground": "#f5eda80e", // active match (the one you’re on)
		"editor.findMatchBorder": "#fa902ccb",
		"editor.findMatchHighlightBackground": "#ffffff00", // all other matches
		"editor.findMatchHighlightBorder": "#feffc686",
		// COLORFUL FOLDERS
		// "folderPathColor.custom_yellow": "#ff8aef",
		//
		"folderPathColor.custom1": "#ffa9c8", // tender enemy
		"folderPathColor.custom2": "#d88ad8", // animation player
		"folderPathColor.custom3": "#c3c78d", // dark misc yellow
		"folderPathColor.custom4": "#a4d4b2", // tender green
		"folderPathColor.custom5": "#94f0c5d5",
		"folderPathColor.custom6": "#dfdfdf", // white
		"folderPathColor.custom7": "#cdcf90", // yellow accent
	},
	//
	// COLORFUL FOLDERS
	// Predefined color names: blue, magenta, red, cyan, green, yellow.
	"folder-path-color.folders": [
		{
			"path": "-assets-",
			"color": "custom3"
		},
		{
			"path": "souls-tut/Enemies/SimpleEnemy",
			"color": "custom1"
		},
		{
			"path": "souls-tut/fancy-camera",
			"color": "custom5"
		},
		{
			"path": "souls-tut/Player/PlayerModel/area_awareness.gd",
			"color": "custom7"
		},
		{
			"path": "souls-tut/Player/PlayerStates/_base_state.gd",
			"color": "custom6"
		},
		{
			"path": "souls-tut/Player/PlayerAnim/split_body_animator.gd",
			"color": "custom2"
		},
	],
	//
	// No built in git color on files (conflict with colorful folders)
	"git.decorations.enabled": false,
	// Fighting with space indents
	"editor.insertSpaces": false,
	"editor.detectIndentation": false,
	// File view more shifted
	"workbench.tree.indent": 14,
	// Probably duplicates my custom edits to theme extension
	"editor.tokenColorCustomizations": {
		"textMateRules": [
			{
				"scope": "entity.name.type.class.gdscript",
				"settings": {
					"foreground": "#2CDFC7E3"
					// "foreground": "#43e0cbc5"
				}
			},
			{
				"scope": "entity.name.function.gdscript",
				"settings": {
					"foreground": "#5ECFE6"
					// "foreground": "#70baff"
				}
			},
			{
				"scope": "variable.other.property.gdscript",
				"settings": {
					"foreground": "#D9BCFF"
					// "foreground": "#e4d0ffe8"
				}
			}
		]
	},
	//
	// HIGHLIGHT EXTENSION
	"highlight.regexes": {
		// Highlight every instance of "A." (e.g., A.my_static_method)
		"\\b(A\\.)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#FFEEA1E5",
					// "fontWeight": "bold"
				}
			]
		},
		// Highlight the action names that follow "InAction."
		"(RawAction\\.)(\\w+)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#FFEEA1E5"
				}, // This applies a subtle color to the "InAction." part
				{
					// "color": "#FFEEA1E5",
				} // This applies the yellow color to the word
			]
		},
		"(PlayerState\\.)(\\w+)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#5da9ff"
				}, // This applies a subtle color to the "InAction." part
				{
					// "color": "#FFEEA1E5",
				} // This applies the yellow color to the word
			]
		},
		"(SEState\\.)(\\w+)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#5da9ff"
				}, // This applies a subtle color to the "InAction." part
				{
					// "color": "#FFEEA1E5",
				} // This applies the yellow color to the word
			]
		},
		"\\b(print_\\.)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#A3A3F5",
				}
			]
		}
	}
