		"(combat)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#ff9b8ef8",
					// "fontWeight": "bold",
				},
				{
					// "color": "#FFEEA1E5",
				}
			]
		},
		"(?<!\\w)(@abstract)(?!\\w)": {
