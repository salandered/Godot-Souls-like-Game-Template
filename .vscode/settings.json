		// BOOKMARKS
		"bookmarks.lineBackground": "#6c6aff22", // Background color for a bookmarked line.
		"bookmarks.lineBorder": "#ffffff00", // Border color for a bookmarked line.
		"bookmarks.overviewRuler": "#157EFB88", // Marker color for the overview ruler.
