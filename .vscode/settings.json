{
	// DYNAMIC
	"editor.hover.enabled": false,
	// "editor.hover.delay": 400,
	//
	//
	// 
	// godot
	"godotTools.editorPath.godot4": "C:\\safe\\godot\\_godot_support\\_v4.5-lts\\Godot_v4.5-stable_win64.exe",
	// exlude from file view
	"files.exclude": {
		// godot 
		"**/*.res": true,
		"**/*.gd.uid": true,
		"**/*.blend": true,
		"**/*.glb": true,
		// images
		"**/*.jpg": true,
		"**/*.png": true,
		"**/*.png.import": true,
		"**/*.jpg.import": true,
		"**/*.svg.import": true,
		"**/*.tmp": true,
		"**/*.TMP": true,
	},
	// godot ends
	// dont open file again in split view
	"workbench.editor.revealIfOpen": true,
	//--------------------------------------------
	//-----------🤖 FIGHTING COPILOT 🤖----------
	//--------------------------------------------
	// Only show code actions on non-empty lines (the old behaviour of code actions): "editor.lightbulb.enabled": "onCode"
	// "github.copilot.editor.enableCodeActions": false, // no yellow stars
	// configured in keybindings.json
	// "editor.inlineSuggest.enabled": true,
