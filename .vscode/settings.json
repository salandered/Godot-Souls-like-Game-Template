{
	// DYNAMIC
	"editor.hover.enabled": "off",
	// "editor.hover.delay": 400,
	// 
	// GODOT
	"godotTools.editorPath.godot4": "C:\\safe\\godot\\_godot_support\\_v4.6.1-stable\\Godot_v4.6.1-stable_win64.exe",
	//
	// FILE EXCLUSION
	"files.exclude": {
		// godot 
		"**/*.res": true,
		// "**/*.tres": true,
		"**/*.gd.uid": true,
		"**/*.blend": true,
		"**/*.glb": true,
		// images
		// "**/*.jpg": true,
		// "**/*.png": true,
		"**/*.png.import": true,
		"**/*.jpg.import": true,
		"**/*.svg.import": true,
		"**/*.ttf.import": true,
		"**/*.JPG.import": true,
		"**/*.tmp": true,
		"**/*.TMP": true,
	},
	"files.watcherExclude": {
		// Default VS Code exclusions
		"**/.git/objects/**": true,
		"**/.git/subtree-cache/**": true,
		"**/.hg/store/**": true,
		// optional
		"**/addons/**": true,
		"**/misc/**": true,
		// "**/-assets-/**": true,
	},
	//--------------------------------------------
	//-----------🤖 FIGHTING COPILOT 🤖----------
	//--------------------------------------------
	// "github.copilot.editor.enableCodeActions": false, // no yellow stars
	// "editor.inlineSuggest.enabled": true, // 🚩 NOTE: currently is configured via keybindings.json
	// "github.copilot.enable": false,
	// "editor.inlineSuggest.syntaxHighlightingEnabled": false,
	//
	// NES settings
	// "github.copilot.nextEditSuggestions.enabled": false,
	// "editor.inlineSuggest.edits.allowCodeShifting": "never",
