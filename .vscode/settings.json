	"bookmarks.label.suggestion": "dontUse",
	//
	//
	// 🔴🟠🟡🟢🔵🟣
	// HIGHLIGHT EXTENSION
	"highlight.regexes": {
		// -- IMPORTANT -- 
		// Godot tools fixes
		"(?<!\\w)(@abstract)(?!\\w)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#ebc47c"
				}
			]
		},
		// comment regions are highlighted
		"(# region)(.*)": {
			"decorations": [
				{
					"color": "#eba0eb80", // for '# region:'
					// "fontStyle": "italic"
				},
				// {
				// "color": "#808080", // optionally for the text after it
				// "fontStyle": "italic"
				// }
			]
		},
		// Default `match` case `_:` is more prominent
		"\\b(_:)(?=\\r?\\n)": {
			"decorations": [
				{
					// "color": "#fff346",
					"fontWeight": "bold",
					"backgroundColor": "#3b5552",
					// "borderRadius": "2px", // Give the box rounded corners
					// "border": "1px dashed #68fff786" // A solid border
				},
			]
		},
		// VALIDATION FRAMEWORK
		"(__hard_dependencies)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#78e2a1d7",
					"fontWeight": "bold",
				}
			]
		},
		"(__soft_dependencies)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#b4e278d7",
					"fontWeight": "bold",
				},
			]
		},
		"(__hard_validation)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#78e2a1d7",
					"fontWeight": "bold",
				},
			]
		},
		"(__soft_validation)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#b4e278d7",
					"fontWeight": "bold",
				},
			]
		},
		"(__validated)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#78e2a1d7",
					"fontWeight": "bold",
				},
			]
		},
		"(__perform_validation)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#78e2a1d7",
					"fontWeight": "bold",
				}
			]
		},
		"\\b(__validation_ok\\(\\))": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#78e2a1d7",
					"fontWeight": "bold",
				}
			]
		},
		// LOGGING FRAMEWORK
		"\\b(__log_[a-zA-Z0-9_]*)(?=\\s*\\()": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#77b2dade",
				}
			]
		},
		"\\b(error_\\.[a-zA-Z0-9_()]*)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#e9a686d2",
					"fontStyle": "italic"
				}
			]
		},
		"\\b(_reason\\s*\\+?=\\s*.*)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#82b1ddd2",
					"fontStyle": "italic"
				}
			]
		},
		"\\b(print_\\.[a-zA-Z_]\\w*)(?=\\s*\\()": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#77b2dade",
				}
			]
		},
		"\\b(print_preset\\.[a-zA-Z_]\\w*)(?=\\s*\\()": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#77b2dade",
				}
			]
		},
		// Engine helpers
		"(is_release\\(\\))": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#ff5fca",
					"backgroundColor": "#06423fa6",
					"fontWeight": "bold",
					// "borderRadius": "2px", // Give the box rounded corners
					// "border": "1px solid #caa495d7" // A solid border
				}
			]
		},
		"(is_editor\\(\\))": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#dfd793",
					"backgroundColor": "#58176b71",
					"fontWeight": "bold",
				}
			]
		},
		// Warn (log) levels 
		"\\b(WL\\.)(\\w+)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#f5a382",
					"fontStyle": "italic"
				},
				{}
			]
		},
		// Built in functions like `_process` more prominent (also some custom, common to project)
		"(?<=func\\s_?)(physics_process)(?=\\()": { // func _physics_process(...)
			"decorations": [
				{
					"textDecoration": "underline double",
				},
			]
		},
		"(?<=func\\s_?)(process)(?=\\()": { // func _physics_process(...)
			"decorations": [
				{
					"textDecoration": "underline double",
				},
			]
		},
		"(?<=func\\s_?)(initialize)(?=\\()": {
			"decorations": [
				{
					"textDecoration": "underline wavy #5ec4d8b2",
				},
			]
		},
		"(?<=func\\s_?)(initialize_implementation)(?=\\()": {
			"decorations": [
				{
					"textDecoration": "underline wavy #5ec4d8b2",
				},
			]
		},
		"(?<=func\\s_?)(update)(?=\\()": { // func update(...)
			"decorations": [
				{
					"textDecoration": "underline double",
				},
			]
		},
		"(on_enter_\\w+)(?=\\()": { // func _on_enter_something() or func on_enter_something()
			"decorations": [
				{
					"textDecoration": "underline #f0c078d5",
				},
			]
		},
		"(on_exit_\\w+)(?=\\()": { // ex (?<=func\\s_?)(on_exit_\\w+)(?=\\()
			"decorations": [
				{
					"textDecoration": "underline #f0c078d5",
				},
			]
		},
