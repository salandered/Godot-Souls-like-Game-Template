{
	// Dynamic Settings
	// "editor.hover.enabled": false,
	// Static settings
	// godot
	"godotTools.editorPath.godot4": "c:\\safe\\godot\\Godot_v4.4.1-stable_win64.exe\\Godot_v4.4.1-stable_win64.exe",
	// exlude from file view
	"files.exclude": {
		// godot 
		"**/*.res": true,
		"**/*.gd.uid": true,
		// images
		"**/*.jpg": true,
		"**/*.png": true,
		"**/*.png.import": true,
		"**/*.jpg.import": true,
		"**/*.svg.import": true,
		"**/*.tmp": true,
	},
	// dont open file again in split view
	"workbench.editor.revealIfOpen": true,
	// against copilot
	"editor.inlineSuggest.enabled": false,
	// FOLDER COLORS EXAMPLE
	// "workbench.colorCustomizations": {
	//     "folderPathColor.custom1": "#FF4488",
	//     "folderPathColor.custom2": "#88ff44",
	// },
	// "folder-path-color.folders": [
	//     {
	//         "path": "frontend",
	//         "symbol": "SR",
	//         "tooltip": "Source files"
	//     },
	// ]
	// COLORS
	"workbench.colorCustomizations": {
		// BUILD IN
		"editor.findMatchBackground": "#f5eda80e", // active match (the one you’re on)
		"editor.findMatchBorder": "#fa902ccb",
		"editor.findMatchHighlightBackground": "#ffffff00", // all other matches
		"editor.findMatchHighlightBorder": "#feffc686",
		// COLORFUL FOLDERS
		"folderPathColor.custom1": "#ffa9c8",
		"folderPathColor.custom2": "#ff8aef",
		"folderPathColor.custom3": "#c3c78d",
		"folderPathColor.custom4": "#a4d4b2",
		"folderPathColor.custom5": "#94f0c5d5",
	},
	// COLORFUL FOLDERS
	"folder-path-color.folders": [
		{
			"path": "-assets-",
			"color": "custom3"
		},
		{
			"path": "scripts/player",
			"color": "custom2"wwda
		},
		{
			"path": "scripts",
			"color": "custom4"
		},
		{
			"path": "souls-tut/Enemies",
			"color": "custom1"
		},
		{
			"path": "souls-tut/fancy-camera",
			"color": "custom5"
		},
	],
	// No built in git color on files (conflict with colorful folders)
	"git.decorations.enabled": false,
	// Fighting with space indents
	"editor.insertSpaces": false,
	"editor.detectIndentation": false,
	// File view more shifted
	"workbench.tree.indent": 14,
	//
	"editor.tokenColorCustomizations": {
		"textMateRules": [
			{
				"scope": "entity.name.type.class.gdscript",
				"settings": {
					"foreground": "#2CDFC7E3"
					// "foreground": "#43e0cbc5"
				}
			},
			{
				"scope": "entity.name.function.gdscript",
				"settings": {
					"foreground": "#5ECFE6"
					// "foreground": "#70baff"
				}
			},
			{
				"scope": "variable.other.property.gdscript",
				"settings": {
					"foreground": "#D9BCFF"
					// "foreground": "#e4d0ffe8"
				}
			}
		]
	},
