	//
	// No built in git color on files (conflict with colorful folders)
	"git.decorations.enabled": false,
	// Fighting with space indents
	"editor.insertSpaces": false,
	"editor.detectIndentation": false,
	// File view more shifted
	"workbench.tree.indent": 12,
	// ========================
	// Bookmarks Extension Settings
	// ========================
	"bookmarks.navigateThroughAllFiles": true, // Allows navigation through all files that contain bookmarks.
	"bookmarks.wrapNavigation": true, // Allows navigation to wrap around at the first and last bookmarks in scope.
	"bookmarks.saveBookmarksInProject": false, //true -> bookmarks are saved in the project, which is useful for version control.
	// Path to another image to be shown as a bookmark icon (16x16 px).
	// "bookmarks.gutterIconPath": "",
	// Enables bookmarks commands to be displayed on the editor context menu.
	"bookmarks.showCommandsInContextMenu": true,
	"bookmarks.experimental.enableNewStickyEngine": true, // Enables the new Sticky engine for improved source change detections and undo operations.
	"bookmarks.keepBookmarksOnLineDelete": false, // If a line with a bookmark is deleted, this keeps the bookmark on the next available line.
	// Workaround for formatters (like Prettier) that break the Sticky engine.
	// Can be turned off if `experimental.enableNewStickyEngine` is true.
	"bookmarks.useWorkaroundForFormatters": false,
	"bookmarks.sideBar.expanded": false, // if the Bookmarks side bar should start expanded.
	// the count badge on the Bookmark icon in the Activity Bar.
	// `all` shows the total count, `files` shows the number of files with bookmarks.
	"bookmarks.sideBar.countBadge": "all",
	"bookmarks.multicursor.toggleMode": "allLinesAtOnce", // how multi-cursor toggles handle bookmarked lines.
	"bookmarks.label.suggestion": "dontUse", // how labels are suggested when creating bookmarks.
	//
	// HIGHLIGHT EXTENSION
	"highlight.regexes": {
		// Highlight every instance of "A." (e.g., A.my_static_method)
		"\\b(A\\.)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#FFEEA1E5",
					// "fontWeight": "bold"
				}
			]
		},
		"\\b(SEA\\.)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#FFEEA1E5",
					// "fontWeight": "bold"
				}
			]
		},
		"\\b(PHEA\\.)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#FFEEA1E5",
					// "fontWeight": "bold"
				}
			]
		},
		"(RawAction\\.)(\\w+)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#FFEEA1E5"
				},
				{
					// "color": "#FFEEA1E5",
				}
			]
		},
		"\\b(PS\\.)(\\w+)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#5da9ff"
				},
				{
					// "color": "#FFEEA1E5",
				}
			]
		},
		"\\b(PS.Act\\.)(\\w+)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#68c3f8"
				},
				{
					// "color": "#FFEEA1E5",
				}
			]
		},
		"\\b(Leg\\.Beh\\.)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#c9ad79f3"
				},
				{
					// "color": "#FFEEA1E5",
				}
			]
		},
		"\\b(Leg\\.Act\\.)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#e9d08ce3"
				},
			]
		},
		"(PlayerState\\.)(\\w+)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#5da9ff"
				},
				{
					// "color": "#FFEEA1E5",
				}
			]
		},
		"(SEState\\.)(\\w+)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#5da9ff"
				},
				{
					// "color": "#FFEEA1E5",
				}
			]
		},
		"(PHEState\\.)(\\w+)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#5da9ff"
				},
				{
					// "color": "#FFEEA1E5",
				}
			]
		},
		"\\b(PHEState\\.Leaf\\.)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#99f5bcee"
				},
			]
		},
		"(traits)(\\.)(\\w+)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#d1d1d1d7",
					"fontWeight": "bold",
					// invalid but works
					"textDecoration": "underline"
				},
				{
					// "color": "#FFEEA1E5",
				}
			]
		},
		"(?<=func\\s_?)(initialise)(?=\\()": {
			"decorations": [
				{
					// "color": "#5ec4d8b2",
					"textDecoration": "underline wavy #5ec4d8b2",
				},
			]
		},
		"(?<=func\\s_?)(update)(?=\\()": { // func update(...)
			"decorations": [
				{
					"textDecoration": "underline double",
				},
			]
		},
		"(on_enter_\\w+)(?=\\()": { // func _on_enter_something() or func on_enter_something()
			"decorations": [
				{
					"textDecoration": "underline #f0c078d5",
				},
			]
		},
		"(on_exit_\\w+)(?=\\()": { // ex (?<=func\\s_?)(on_exit_\\w+)(?=\\()
			"decorations": [
				{
					"textDecoration": "underline #f0c078d5",
				},
			]
		},
		"\\b(__log_[a-zA-Z0-9_]*)(?=\\s*\\()": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#77b2dade",
				}
			]
		},
		"\\b(print_\\.[a-zA-Z_]\\w*)(?=\\s*\\()": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#77b2dade",
				}
			]
		},
		"(# region:)(.*)": {
			"decorations": [
				{
					"color": "#eba0eb80", // Style for '# region:'
					// "fontStyle": "italic"
				},
				// {
				// "color": "#808080", // Style for the text after it
				// "fontStyle": "italic"
				// }
			]
		},
		"(stamina)": {
			"filterLanguageRegex": "gdscript",
