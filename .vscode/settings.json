				}
			]
		},
		"\\b(prev_prev_blend_playback)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#eca593f3"
				},
				{
					// "color": "#FFEEA1E5",
				}
			]
		},
		"\\b(prev_blend_playback)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#8bb8f1fa"
				},
				{
					// "color": "#FFEEA1E5",
				}
			]
		},
		"\\b(curr_blend_playback)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#e9c582f3"
				},
				{
					// "color": "#FFEEA1E5",
				}
			]
		},
		"\\b(curr_global_action)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#ecc893",
					"fontWeight": "bold",
				},
				{
					// "color": "#FFEEA1E5",
				}
			]
		},
		"\\b(curr_state_action)": {
			"filterLanguageRegex": "gdscript",
			"decorations": [
				{
					"color": "#96c3eeec",
					"fontWeight": "bold",
				},
				{
					// "color": "#FFEEA1E5",
				}
			]
