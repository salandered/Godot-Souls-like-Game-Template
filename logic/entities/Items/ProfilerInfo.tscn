[node name="AdditionalMovementTips" type="MarginContainer" parent="CanvasLayer/MarginContainer/VBoxContainer/TutorialPanel/TutorialLabels"]
unique_name_in_owner = true
layout_mode = 2

[node name="vb" type="VBoxContainer" parent="CanvasLayer/MarginContainer/VBoxContainer/TutorialPanel/TutorialLabels/AdditionalMovementTips"]
layout_mode = 2

[node name="RichTextLabel" parent="CanvasLayer/MarginContainer/VBoxContainer/TutorialPanel/TutorialLabels/AdditionalMovementTips/vb" instance=ExtResource("4_rrtea")]
layout_mode = 2
theme_override_font_sizes/normal_font_size = 24
theme_override_font_sizes/bold_font_size = 26
text = "[b]Advanced dodge[/b] - press and immediately release the [img=20x20]res://-assets-/x_icons/white/steps.png[/img] [i]move button[/i] before performing a dodge. This will make you dodge as if you were being in a target-lock mode. Pretty handy against the projectiles. 
[b]Sprint jump[/b] - you guessed it, just jump while sprinting. 
[b]Advanced target movement[/b] - you can not only sprint, but also run freely while being in target-lock mode. In order to do so double-tap the [img=20x20]res://-assets-/x_icons/white/icon_target_2.png[/img] [i]target lock button[/i] while already being in [img=20x20]res://-assets-/x_icons/white/icon_target_2.png[/img] target lock mode. Double tapping again will switch you back to strafing."
plain_text = "Advanced dodge - press and immediately release the move button before performing a dodge. This will make you dodge as if you were being in a target-lock mode. Pretty handy against the projectiles. 
Sprint jump - you guessed it, just jump while sprinting. 
Advanced target movement - you can not only sprint, but also run freely while being in target-lock mode. In order to do so double-tap the target lock button while already being in target lock mode. Double tapping again will switch you back to strafing.
"
italic_phrases = Array[String](["attack button", "move button", "dodge button", "target lock button"])
phrase_icons = Dictionary[String, String]({
"attack button": "res://-assets-/x_icons/white/icon_sword.png",
"move button": "res://-assets-/x_icons/white/steps.png",
"target lock": "res://-assets-/x_icons/white/icon_target_2.png"
})

