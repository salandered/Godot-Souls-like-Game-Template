[node name="RichTextLabel" parent="CanvasLayer/MarginContainer/VBoxContainer/TutorialPanel/TutorialLabels/HighLights/vb" instance=ExtResource("4_rrtea")]
layout_mode = 2
theme_override_font_sizes/normal_font_size = 24
theme_override_font_sizes/bold_font_size = 26
text = "[b]Full combo[/b] - press [img=20x20]res://-assets-/x_icons/white/icon_sword.png[/img] [i]attack button[/i] three times to make a full three hit combo. Note how you can change direction of the last powerful hit using [img=20x20]res://-assets-/x_icons/white/steps.png[/img] [i]move button[/i]s.
[b]Running attack[/b] - press [img=20x20]res://-assets-/x_icons/white/icon_sword.png[/img] [i]attack button[/i] while sprinting (you can't do that right after you start sprinting)
[b]Dodge attack[/b] - press [img=20x20]res://-assets-/x_icons/white/icon_sword.png[/img] [i]attack button[/i] right after dodging. Forward dodge results in stab almost immediately. 
[b]U-turn[/b] - press the opposite [img=20x20]res://-assets-/x_icons/white/steps.png[/img] [i]move button[/i] while sprinting.
[b]Target locking[/b] - you can practice strafing while being in target-lock mode using static targets in the scene (golden posts). Use vertical mouse movement to adjust the view. Note that you may sprint freely while in target-lock mode.
[b]Destructible columns[/b] - let the enemy hit the column! It's a lot of fun.
[b]Fighting several enemies at once[/b] - just find the way to reach additional enemies."
plain_text = "Full combo - press attack button three times to make a full three hit combo. Note how you can change direction of the last powerful hit using move buttons.
Running attack - press attack button while sprinting (you can't do that right after you start sprinting)
Dodge attack - press attack button right after dodging. Forward dodge results in stab almost immediately. 
U-turn - press the opposite move button while sprinting.
Target locking - you can practice strafing while being in target-lock mode using static targets in the scene (golden posts). Use vertical mouse movement to adjust the view. Note that you may sprint freely while in target-lock mode.
Destructible columns - let the enemy hit the column! It's a lot of fun.
Fighting several enemies at once - just find the way to reach additional enemies."
italic_phrases = Array[String](["attack button", "move button", "dodge button", "target lock button"])
phrase_icons = Dictionary[String, String]({
"attack button": "res://-assets-/x_icons/white/icon_sword.png",
"move button": "res://-assets-/x_icons/white/steps.png",
"target lock": "res://-assets-/x_icons/white/icon_target_2.png"
})

