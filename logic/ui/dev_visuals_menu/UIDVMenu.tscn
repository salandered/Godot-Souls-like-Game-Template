layout_mode = 2
tooltip_text = "Shows info about the character's State Machine. 
E.g.: current state name.
Visualizes updates by animating the previous value
dropping down and fading out as a \"ghost\". 
This behaviour can be configured."

[node name="MarginContainer3" type="MarginContainer" parent="MarginContainer/VBoxContainer/HBoxContainer/VBoxContainer/RockPanelCharSpecificInfo/__v/__rock_margin/VBoxContainer/HBoxContainer2/__m_ToolTip/VBoxContainer"]
