text = "[ul]
[b]WASD[/b] - [img=20x20]uid://bmwjt7mmr0hy8[/img] move
[b]Space[/b] - [img=20x20]uid://covd6kks862ko[/img] dodge/jump
[b]Shift[/b] - sprint
[b]Q[/b] - [img=20x20]uid://dp2m7ljkctl4[/img] target lock
