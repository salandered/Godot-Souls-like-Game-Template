[node name="LegendText" parent="CanvasLayer/ProfilerAndTutorial/VBoxContainer/FirstTutorialPanel/margin10/TutorialLabels/Legend/vb" instance=ExtResource("5_0xnqb")]
layout_mode = 2
theme_override_font_sizes/normal_font_size = 24
theme_override_font_sizes/bold_font_size = 24
theme_override_font_sizes/italics_font_size = 20
text = "[b]press 1[/b] - to see [img=20x20]res://-assets-/x_icons/white/icon_lever.png[/img] controls.
[b]press 2[/b] - to learn about [img=20x20]res://-assets-/x_icons/white/icon_parchment.png[/img] available mechanics.
[b]press 3[/b] - to learn more about [img=20x20]res://-assets-/x_icons/white/icon_sword.png[/img] combo attacks.
[b]press 4[/b] - to learn more about [img=20x20]res://-assets-/x_icons/white/icon_target_2.png[/img] target locking.
[b]press 5[/b] - to learn more about [img=20x20]res://-assets-/x_icons/white/icon_heart.png[/img] health/stamina.
[b]press 6[/b] - to see some [img=20x20]res://-assets-/x_icons/white/icon_light_bulb.png[/img] additional info.
[b]press 0[/b] - to hide/unhide all.

[i]Pressing the same number hides the dedicated panel.[/i]"
plain_text = "press 1 - to see controls.
press 2 - to learn about available mechanics.
press 3 - to learn more about combo attacks.
press 4 - to learn more about target locking.
press 5 - to learn more about health/stamina.
press 6 - to see some additional info.
press 0 - to hide/unhide all.

Pressing the same number hides the dedicated panel."
italic_phrases = Array[String](["Pressing the same number hides the dedicated panel."])
phrase_icons = Dictionary[String, String]({
"additional info": "res://-assets-/x_icons/white/icon_light_bulb.png",
