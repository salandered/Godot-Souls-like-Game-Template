[node name="3AttackMechanic" type="MarginContainer" parent="CanvasLayer/ProfilerAndTutorial/VBoxContainer/FirstTutorialPanel/margin10/TutorialLabels"]
unique_name_in_owner = true
visible = false
layout_mode = 2

[node name="vb" type="VBoxContainer" parent="CanvasLayer/ProfilerAndTutorial/VBoxContainer/FirstTutorialPanel/margin10/TutorialLabels/3AttackMechanic"]
layout_mode = 2

[node name="RichTextLabel" parent="CanvasLayer/ProfilerAndTutorial/VBoxContainer/FirstTutorialPanel/margin10/TutorialLabels/3AttackMechanic/vb" instance=ExtResource("5_0xnqb")]
layout_mode = 2
theme_override_font_sizes/normal_font_size = 24
theme_override_font_sizes/bold_font_size = 26
text = "[b]Heavy attack[/b] - just press heavy [img=20x20]res://-assets-/x_icons/white/icon_sword.png[/img] [i]attack button[/i].

[b]Light combo[/b] - press light [img=20x20]res://-assets-/x_icons/white/icon_sword.png[/img] [i]attack button[/i] two times. 

[b]Full combo[/b] - make light combo and then press heavy [img=20x20]res://-assets-/x_icons/white/icon_sword.png[/img] [i]attack button[/i]. Note that heavy attack is faster (and deadlier) if it comes at the end of the Full combo.
[b]Running attack[/b] - press [img=20x20]res://-assets-/x_icons/white/icon_sword.png[/img] [i]attack button[/i] while sprinting.

[b]Dodge attack[/b] - press [img=20x20]res://-assets-/x_icons/white/icon_sword.png[/img] [i]attack button[/i] right after dodging. Forward dodge results in stab almost immediately. 

[img=20x20]res://-assets-/x_icons/white/icon_interrogation.png[/img] Help: If combo attack is not triggered, try to press [img=20x20]res://-assets-/x_icons/white/icon_sword.png[/img] [i]attack button[/i] closer to the end of the current attack (less spam the clicks).

[img=20x20]res://-assets-/x_icons/white/icon_light_bulb.png[/img] Tip: you can change direction in the middle of some attacks if not [img=20x20]res://-assets-/x_icons/white/icon_target_2.png[/img] target locked."
plain_text = "Heavy attack - just press heavy attack button.

Light combo - press light attack button two times. 

Full combo - make light combo and then press heavy attack button. Note that heavy attack is faster (and deadlier) if it comes at the end of the Full combo.
Running attack - press attack button while sprinting.

Dodge attack - press attack button right after dodging. Forward dodge results in stab almost immediately. 

Help: If combo attack is not triggered, try to press attack button closer to the end of the current attack (less spam the clicks).

Tip: you can change direction in the middle of some attacks if not target locked."
italic_phrases = Array[String](["attack button", "move button", "dodge button", "target lock button"])
phrase_icons = Dictionary[String, String]({
"Help:": "res://-assets-/x_icons/white/icon_interrogation.png",
"Tip:": "res://-assets-/x_icons/white/icon_light_bulb.png",
"attack button": "res://-assets-/x_icons/white/icon_sword.png",
"move button": "res://-assets-/x_icons/white/steps.png",
"target lock": "res://-assets-/x_icons/white/icon_target_2.png"
})

