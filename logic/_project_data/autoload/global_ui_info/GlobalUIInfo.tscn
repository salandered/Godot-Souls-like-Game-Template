text = "[b]WASD[/b] - [img=20x20]res://-assets-/x_icons/white/steps.png[/img] move
[b]Space[/b] - dodge/jump
[b]Shift[/b] - sprint
[b]Q[/b] - [img=20x20]res://-assets-/x_icons/white/icon_target_2.png[/img] target lock
[b]LMB[/b] - [img=20x20]res://-assets-/x_icons/white/icon_sword.png[/img] light attack
[b]RMB[/b] - [img=20x20]res://-assets-/x_icons/white/icon_sword.png[/img] heavy attack
[b]E[/b] - interact
[b]F[/b] - switch weapon
[b]Esc[/b] -  pause
[i]H to unstuck (just in case)[/i]
[i]F3 to see profiler[/i]
[i]F9 to toggle flying dev camera[/i]"
plain_text = "WASD - move
Space - dodge/jump
Shift - sprint
Q - target lock
LMB - light attack
RMB - heavy attack
E - interact
F - switch weapon
Esc -  pause
H to unstuck (just in case)
F3 to see profiler
F9 to toggle flying dev camera
"
