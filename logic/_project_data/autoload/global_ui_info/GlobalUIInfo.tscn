[node name="RichTextLabel" parent="CanvasLayer/ProfilerAndTutorial/VBoxContainer/FirstTutorialPanel/margin10/TutorialLabels/5HealthStaminaMechanic/vb" instance=ExtResource("5_0xnqb")]
layout_mode = 2
theme_override_font_sizes/normal_font_size = 24
theme_override_font_sizes/bold_font_size = 26
text = "[b]Stamina management[/b] - some moves drains stamina, while standing idle or running will help replenish it.

[b]Stamina fatigue[/b] - when stamina hits zero, you won't be able to make stamina draining moves for a little while. Stamina bar will be painted in yellow and you also will hear a sound clue if a move is not allowed.

[b]Chest items[/b] - you will find pickable items which would help you to improve health and also increase the maximum health/stamina."
plain_text = "Stamina management - some moves drains stamina, while standing idle or running will help replenish it.

Stamina fatigue - when stamina hits zero, you won't be able to make stamina draining moves for a little while. Stamina bar will be painted in yellow and you also will hear a sound clue if a move is not allowed.

Chest items - you will find pickable items which would help you to improve health and also increase the maximum health/stamina."
italic_phrases = Array[String](["attack button", "move button", "dodge button", "target lock button"])
