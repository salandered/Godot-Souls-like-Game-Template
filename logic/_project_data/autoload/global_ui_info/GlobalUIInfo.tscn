[node name="2MechanicsOverview" type="MarginContainer" parent="CanvasLayer/ProfilerAndTutorial/VBoxContainer/FirstTutorialPanel/margin10/TutorialLabels"]
unique_name_in_owner = true
visible = false
layout_mode = 2

[node name="vb" type="VBoxContainer" parent="CanvasLayer/ProfilerAndTutorial/VBoxContainer/FirstTutorialPanel/margin10/TutorialLabels/2MechanicsOverview"]
layout_mode = 2

[node name="RichTextLabel" parent="CanvasLayer/ProfilerAndTutorial/VBoxContainer/FirstTutorialPanel/margin10/TutorialLabels/2MechanicsOverview/vb" instance=ExtResource("5_0xnqb")]
layout_mode = 2
theme_override_font_sizes/normal_font_size = 24
theme_override_font_sizes/bold_font_size = 26
text = "[b]Attacks and combos[/b] - press light and heavy [img=20x20]res://-assets-/x_icons/white/icon_sword.png[/img] [i]attack button[/i]s adjusting timings to learn combos. Also see a tutorial panel about combos.

[b]Switching weapons[/b] - Use the [i]switch weapon button[/i]. Note that you can't switch in the middle of the current attack (sound clue will help you notice that)

[b]Target locking[/b] - see the dedicated tutorial panel.

[b]Destructible columns[/b] - let the enemy hit the colum, or use more powerful weapon. If you are lucky enough, you will break a column while being thrown away at it by the enemy...

[b]Fighting several enemies at once[/b] - just find the way to reach additional enemies. It's a lot of fun and they could accidently hit each other as well.

[b]Chests and items[/b] - open chests to find helpful items and improve your abilities (e.g. longer dodge).
[b]Health/Stamina[/b] - see the dedicated tutorial."
plain_text = "Attacks and combos - press light and heavy attack buttons adjusting timings to learn combos. Also see a tutorial panel about combos.

Switching weapons - Use the switch weapon button. Note that you can't switch in the middle of the current attack (sound clue will help you notice that)

Target locking - see the dedicated tutorial panel.

Destructible columns - let the enemy hit the column, or use more powerful weapon. If you are lucky enough, you will break a column while being thrown away at it by the enemy...

Fighting several enemies at once - just find the way to reach additional enemies. It's a lot of fun and they could accidently hit each other as well.

Chests and items - open chests to find helpful items and improve your abilities (e.g. longer dodge).
Health/Stamina - see the dedicated tutorial.
"
italic_phrases = Array[String](["attack button", "move button", "dodge button", "target lock button", "switch weapon button", "attack buttons", ""])
phrase_icons = Dictionary[String, String]({
"Tip": "res://-assets-/x_icons/white/icon_light_bulb.png",
"attack buttons": "res://-assets-/x_icons/white/icon_sword.png",
"move button": "res://-assets-/x_icons/white/steps.png",
"target lock": "res://-assets-/x_icons/white/icon_target_2.png"
})

