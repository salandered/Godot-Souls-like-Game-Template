[node name="4TargetLockMechanic" type="MarginContainer" parent="CanvasLayer/ProfilerAndTutorial/VBoxContainer/FirstTutorialPanel/margin10/TutorialLabels"]
unique_name_in_owner = true
visible = false
layout_mode = 2

[node name="vb" type="VBoxContainer" parent="CanvasLayer/ProfilerAndTutorial/VBoxContainer/FirstTutorialPanel/margin10/TutorialLabels/4TargetLockMechanic"]
layout_mode = 2

[node name="RichTextLabel" parent="CanvasLayer/ProfilerAndTutorial/VBoxContainer/FirstTutorialPanel/margin10/TutorialLabels/4TargetLockMechanic/vb" instance=ExtResource("5_0xnqb")]
layout_mode = 2
theme_override_font_sizes/normal_font_size = 24
theme_override_font_sizes/bold_font_size = 26
text = "[b]Target locking[/b] - find the suitable target and press [img=20x20]res://-assets-/x_icons/white/icon_target_2.png[/img] [i]target lock button[/i]. It will allow you to strafe around the target and make you hits more focused. Note that you may sprint freely while in target-lock mode.

[b]Static targets[/b] - you can practice strafing while being in target-lock mode using static targets (golden posts). 

[img=20x20]res://-assets-/x_icons/white/icon_light_bulb.png[/img] Tip: use vertical mouse movement to adjust the view. 

[img=20x20]res://-assets-/x_icons/white/icon_light_bulb.png[/img] Advanced tip: you can not only sprint, but also run freely while being in target-lock mode. In order to do so double-tap the [img=20x20]res://-assets-/x_icons/white/icon_target_2.png[/img] [i]target lock button[/i] while already being in [img=20x20]res://-assets-/x_icons/white/icon_target_2.png[/img] target lock mode. Double tapping again will switch you back to strafing."
plain_text = "Target locking - find the suitable target and press target lock button. It will allow you to strafe around the target and make you hits more focused. Note that you may sprint freely while in target-lock mode.

Static targets - you can practice strafing while being in target-lock mode using static targets (golden posts). 

Tip: use vertical mouse movement to adjust the view. 

Advanced tip: you can not only sprint, but also run freely while being in target-lock mode. In order to do so double-tap the target lock button while already being in target lock mode. Double tapping again will switch you back to strafing."
italic_phrases = Array[String](["attack button", "move button", "dodge button", "target lock button"])
phrase_icons = Dictionary[String, String]({
"Advanced tip:": "res://-assets-/x_icons/white/icon_light_bulb.png",
"Help:": "res://-assets-/x_icons/white/icon_interrogation.png",
"Tip:": "res://-assets-/x_icons/white/icon_light_bulb.png",
"attack button": "res://-assets-/x_icons/white/icon_sword.png",
"move button": "res://-assets-/x_icons/white/steps.png",
"target lock": "res://-assets-/x_icons/white/icon_target_2.png"
})

