layout_mode = 2

[node name="vb" type="VBoxContainer" parent="CanvasLayer/ProfilerAndTutorial/VBoxContainer/FirstTutorialPanel/margin10/TutorialLabels/6AdditionalMovementTips"]
layout_mode = 2

[node name="RichTextLabel" parent="CanvasLayer/ProfilerAndTutorial/VBoxContainer/FirstTutorialPanel/margin10/TutorialLabels/6AdditionalMovementTips/vb" instance=ExtResource("5_0xnqb")]
layout_mode = 2
theme_override_font_sizes/normal_font_size = 24
theme_override_font_sizes/bold_font_size = 26
text = "[b]Advanced dodge[/b] - press both the [img=20x20]res://-assets-/x_icons/white/steps.png[/img] [i]move button[/i] and [i]dodge button[/i] simultaneously and then immediately release them. This will make you dodge as if you were being in a target-lock mode. Pretty handy against the projectiles. 

[b]Sprint jump[/b] - just jump while sprinting!

[b]U-turn[/b] - press the opposite [img=20x20]res://-assets-/x_icons/white/steps.png[/img] [i]move button[/i] while sprinting. Helps for quick retreats.

[b]Sprint start[/b] - press shift while idle and start moving. It looks cool but not really helpful."
plain_text = "Advanced dodge - press both the move button and dodge button simultaneously and then immediately release them. This will make you dodge as if you were being in a target-lock mode. Pretty handy against the projectiles. 

Sprint jump - just jump while sprinting!

U-turn - press the opposite move button while sprinting. Helps for quick retreats.

Sprint start - press shift while idle and start moving. It looks cool but not really helpful.

"
italic_phrases = Array[String](["attack button", "move button", "dodge button", "target lock button"])
phrase_icons = Dictionary[String, String]({
"attack button": "res://-assets-/x_icons/white/icon_sword.png",
"move button": "res://-assets-/x_icons/white/steps.png",
"target lock": "res://-assets-/x_icons/white/icon_target_2.png"
})

