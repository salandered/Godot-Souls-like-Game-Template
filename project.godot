; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="RetroRoom"
run/main_scene="uid://bco760cyuo8em"
config/features=PackedStringArray("4.4", "Forward Plus")
config/icon="res://icon.svg"

[debug]

gdscript/warnings/unused_variable=0
gdscript/warnings/unused_local_constant=0
gdscript/warnings/unused_private_class_variable=0
gdscript/warnings/unused_parameter=0
gdscript/warnings/unused_signal=0

[editor]

version_control/plugin_name="GitPlugin"
version_control/autoload_on_startup=true

[editor_plugins]

enabled=PackedStringArray("res://addons/favorite_scenes/plugin.cfg", "res://addons/terrain_3d/plugin.cfg")

[file_customization]

folder_colors={
"res://-assets-/": "yellow",
"res://-assets-/animations/": "orange",
"res://-assets-/icons/": "gray",
"res://-assets-/level/": "green",
"res://-assets-/player/": "pink",
"res://addons/": "gray",
"res://misc/": "gray",
"res://misc/trash_bin/": "red",
"res://raw_imports/": "gray",
"res://scenes/actors/": "teal",
"res://scenes/level/": "green",
"res://scenes/player/": "pink",
"res://scripts/player/": "pink"
}

