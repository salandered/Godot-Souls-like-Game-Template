; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

warnings/check_invalid_track_paths=false

[application]

config/name="RetroRoom"
run/main_scene="uid://dmp13e1xswsm0"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

CameraMode="*res://logic/xUtils/ui/CameraMode.tscn"
Settings="*res://ui/settings.gd"
FullscreenHandler="*res://ui/fullscreen_handler.gd"

[debug]

gdscript/warnings/unused_variable=0
gdscript/warnings/unused_local_constant=0
gdscript/warnings/unused_private_class_variable=0
gdscript/warnings/unused_parameter=0
gdscript/warnings/unused_signal=0

[display]

window/size/always_on_top=true

[editor_plugins]

enabled=PackedStringArray("res://addons/favorite_scenes/plugin.cfg")

[file_customization]

folder_colors={
"res://-assets-/GLB-level/": "green",
"res://-assets-/animations/": "yellow",
"res://-assets-/animations/GLB-packed-anim-old/": "gray",
"res://-assets-/animations/GLB-packed/": "blue",
"res://-assets-/animations/Ready-anim/": "gray",
"res://-assets-/animations/Ready-anim/Gundyr/": "pink",
"res://-assets-/animations/Ready-anim/_backups/": "gray",
"res://-assets-/animations/Ready-anim/_forged/": "red",
"res://-assets-/animations/Ready-anim/shield-sword/": "blue",
"res://-assets-/animations/animation-30/": "yellow",
"res://-assets-/animations/standard-skeleton/": "blue",
"res://-assets-/blender_sources/": "orange",
"res://-assets-/blender_sources/player/": "pink",
"res://-assets-/materials-shared/": "red",
"res://-assets-/raw_imports/": "orange",
"res://-assets-/x_blend/": "orange",
"res://-assets-/x_icons/": "gray",
"res://addons/": "gray",
"res://logic/Enemies/Gundyr/": "pink",
"res://logic/Enemies/Gundyr/states/leafes/": "green",
"res://misc/": "gray",
"res://misc/cats-souls/": "purple",
"res://misc/trash_bin/": "red"
}

[global_group]

debug_cameras=""

[importer_defaults]

scene={
&"blender/meshes/tangents": false,
&"meshes/generate_lods": false,
&"meshes/light_baking": 0
}

