:"uniform_4","from_port":0,"to":"blend2_2","to_port":1},{"from":"math","from_port":0,"to":"reroute","to_port":0},{"from":"uniform_2","from_port":0,"to":"blend2","to_port":0}],"label":"Graph","longdesc":"","name":"_Node_653","node_position":{"x":0.0,"y":0.0},"nodes":[{"export":{},"export_last_target":"Godot/Godot 4","export_paths":{"Godot/Godot 4":"/Users/lmw/Desktop/DSK/git/godot/material-test/materials/test"},"name":"Material","node_position":{"x":1943.55603027344,"y":33.2060203552246},"parameters":{"albedo_color":{"a":1.0,"b":1.0,"g":1.0,"r":1.0,"type":"Color"},"ao":0.0,"emission_energy":0.0,"flags_transparent":true,"iter":24.0,"metallic":0.0,"normal":1.34,"offset_scale":0.26,"roughness":1.0,"size":10.0},"seed_int":0,"shader_model":{"code":"","exports":{"Godot/Godot 4":{"export_extension":"tres","files":[{"file_name":"$(path_prefix).gdshader","prompt_overwrite":false,"template":"shader_type spatial;\nrender_mode blend_mix,cull_back,diffuse_burley,specular_schlick_ggx\n$if $(connected:opacity_tex) and $(param:flags_transparent)\n,depth_prepass_alpha\n$fi\n;\nuniform sampler2D texture_albedo; // $output(0)\nuniform sampler2D texture_emission : hint_default_black; // $output(2)\nuniform sampler2D texture_normal : hint_normal; // $output(3)\nuniform sampler2D texture_orm : hint_default_white; // $output(1)\nuniform sampler2D texture_parallax; // $output(5)\nuniform vec3 uv1_scale;\nuniform vec3 uv1_offset;\n$definitions float_uniform_to_const, rename_buffers\nvoid vertex() {\n\tUV=UV*uv1_scale.xy+uv1_offset.xy;\n}\nvoid fragment() {\n\tvec2 base_uv = UV;\n\tint texture_size = textureSize(texture_albedo, 0).x;\n\tif (texture_size < 256) {\n\t\tbase_uv = floor(float(texture_size)*base_uv+0.5)/float(texture_size);\n\t}\n\tvec3 parallax = vec3(0.0);\n$if $(connected:parallax_tex)\n\t{\n$begin_generate\n\t\tint p_iter = int($iter);\n$end_generate\n\t\tvec3 view_dir = inverse(mat3(TANGENT, -BINORMAL, NORMAL))*VIEW;\n\t\tfor (int j = 0; j < p_iter; j++) {\n\t\t\tfloat ratio = float(j) / float(p_iter);\n$begin_generate\n\t\t\tparallax += texture(texture_parallax, base_uv - mix(0.0, $offset_scale, ratio) * view_dir.xy).rgb * mix(1.0, 0.0, ratio);\n$end_generate\n\t\t}\n\t\tparallax /= float(p_iter);\n\t}\n$fi\n$begin_generate rename_buffers\n\tvec4 albedo_tex = texture(texture_albedo, base_uv);\n\tALBEDO = $albedo_color.rgb * mix(pow((albedo_tex + vec4(0.055))/vec4(1.055), vec4(2.4)), albedo_tex/vec4(12.92), lessThan(albedo_tex, vec4(0.04045))).rgb;\n\tALBEDO += parallax;\n\tvec4 orm_tex = texture(texture_orm, base_uv);\n\tMETALLIC = $metallic*orm_tex.b;\n\tROUGHNESS = $roughness*orm_tex.g;\n\tSPECULAR = 0.5;\n\tNORMAL_MAP = texture(texture_normal, base_uv).rgb;\n\tNORMAL_MAP_DEPTH = $normal;\n\tvec3 emission_tex = texture(texture_emission, base_uv).rgb;\n\tEMISSION = emission_tex*$emission_energy;\n\tAO = orm_tex.r;\n\tAO_LIGHT_AFFECT = $ao;\n$if $(connected:opacity_tex) and $(param:flags_transparent)\n\tALPHA = albedo_tex.a;\n\tALPHA_SCISSOR_THRESHOLD = 0.01;\n$fi\n$end_generate\n}\n","type":"template"},{"file_name":"$(path_prefix).tres","prompt_overwrite":false,"template":"[gd_resource type=\"ShaderMaterial\" load_steps=6 format=2]\n[ext_resource path=\"$(file_prefix).gdshader\" type=\"Shader\" id=1]\n$if $(connected:albedo_tex)\n[ext_resource path=\"$(file_prefix)_albedo.png\" type=\"Texture\" id=2]\n$fi\n$if $(connected:normal_tex)\n[ext_resource path=\"$(file_prefix)_normal.png\" type=\"Texture\" id=3]\n$fi\n$if $(connected:ao_tex) or $(connected:roughness_tex) or $(connected:metallic_tex)\n[ext_resource path=\"$(file_prefix)_orm.png\" type=\"Texture\" id=4]\n$fi\n$if $(connected:parallax_tex)\n[ext_resource path=\"$(file_prefix)_parallax.png\" type=\"Texture\" id=5]\n$fi\n$if $(connected:emission_tex)\n[ext_resource path=\"$(file_prefix)_emissoin.png\" type=\"Texture\" id=6]\n$fi\n[resource]\nshader = ExtResource( 1 )\n$if $(connected:albedo_tex)\nshader_parameter/texture_albedo = ExtResource( 2 )\n$fi\n$if $(connected:normal_tex)\nshader_parameter/texture_normal = ExtResource( 3 )\n$fi\n$if $(connected:ao_tex) or $(connected:roughness_tex) or $(connected:metallic_tex)\nshader_parameter/texture_orm = ExtResource( 4 )\n$fi\n$if $(connected:parallax_tex)\nshader_parameter/texture_parallax = ExtResource( 5 )\n$fi\n$if $(connected:emission_tex)\nshader_parameter/texture_emission = ExtResource( 6 )\n$fi\n$if $(connected:emission_tex)\nemission_enabled = true\nemission = Color( 0, 0, 0, 1 )\nemission_energy = $(param:emission_energy)\nemission_operator = 0\nemission_texture = ExtResource( 5 )\n$fi\n$if $(connected:normal_tex)\nnormal_enabled = true\n$fi\nshader_parameter/uv1_scale = Vector3(1, 1, 0)\n","type":"template"},{"conditions":"$(connected:albedo_tex)","file_name":"$(path_prefix)_albedo.png","output":0.0,"prompt_overwrite":false,"type":"texture"},{"conditions":"$(connected:normal_tex)","file_name":"$(path_prefix)_normal.png","output":3.0,"prompt_overwrite":false,"type":"texture"},{"conditions":"$(connected:ao_tex) or $(connected:roughness_tex) or $(connected:metallic_tex)","file_name":"$(path_prefix)_orm.png","output":1.0,"prompt_overwrite":false,"type":"texture"},{"conditions":"$(connected:parallax_tex)","file_name":"$(path_prefix)_parallax.png","output":5.0,"prompt_overwrite":false,"type":"texture"},{"conditions":"$(connected:emission_tex)","file_name":"$(path_prefix)_emission.png","output":2.0,"prompt_overwrite":false,"type":"texture"}]}},"global":"","inputs":[{"default":"vec3(1.0)","label":"","name":"albedo_tex","type":"rgb"},{"default":"1.0","label":"","name":"metallic_tex","type":"f"},{"default":"1.0","label":"","name":"roughness_tex","type":"f"},{"default":"vec3(0.0)","label":"","name":"emission_tex","type":"rgb"},{"default":"vec3(0.5)","label":"","name":"normal_tex","type":"rgb"},{"default":"1.0","label":"","name":"ao_tex","type":"f"},{"default":"vec3(1.0)","label":"","name":"parallax_tex","type":"rgb"},{"default":"1.0","label":"","name":"opacity_tex","type":"f"}],"instance":"","longdesc":"PBR material with maps generated as static images","name":"Static PBR Material Parallax","outputs":[{"rgba":"vec4($albedo_tex($uv), $opacity_tex($uv))","type":"rgba"},{"rgb":"vec3($ao_tex($uv), $roughness_tex($uv), $metallic_tex($uv))","type":"rgb"},{"rgb":"$emission_tex($uv)","type":"rgb"},{"rgb":"$normal_tex($uv)*vec3(-1.0, 1.0, -1.0)+vec3(1.0, 0.0, 1.0)","type":"rgb"},{"f":"clamp($depth_tex($uv), 0.0, 1.0)","type":"f"},{"rgb":"$parallax_tex($uv)","type":"rgb"},{"rgba":"vec4(vec3($metallic_tex($uv)), 1.0-$roughness_tex($uv))","type":"rgba"},{"rgb":"$normal_tex($uv)*vec3(-1.0, 1.0, -1.0)+vec3(1.0, 0.0, 1.0)","type":"rgb"},{"f":"1.0-$depth_tex($uv)","type":"f"},{"f":"$ao_tex($uv)","type":"f"},{"rgb":"$normal_tex($uv)*vec3(-1.0)+vec3(1.0)","type":"rgb"},{"rgba":"vec4($metallic_tex($uv), $ao_tex($uv), 1.0, 1.0-$roughness_tex($uv))","type":"rgba"},{"f":"$metallic_tex($uv)","type":"f"},{"f":"$roughness_tex($uv)","type":"f"}],"parameters":[{"default":{"a":1.0,"b":1.0,"g":1.0,"r":1.0},"label":"Albedo","name":"albedo_color","type":"color"},{"control":"None","default":1.0,"label":"Metallic","max":1.0,"min":0.0,"name":"metallic","step":0.01,"type":"float"},{"control":"None","default":1.0,"label":"Roughness","max":1.0,"min":0.0,"name":"roughness","step":0.01,"type":"float"},{"control":"None","default":1.0,"label":"Emission","max":1.0,"min":0.0,"name":"emission_energy","step":0.01,"type":"float"},{"control":"None","default":1.0,"label":"Normal","max":10.0,"min":0.0,"name":"normal","step":0.01,"type":"float"},{"control":"None","default":1.0,"label":"Ambient occlusion","max":1.0,"min":0.0,"name":"ao","step":0.01,"type":"float"},{"control":"None","default":0.5,"label":"Parallax","max":1.0,"min":0.0,"name":"offset_scale","step":0.01,"type":"float"},{"default":false,"label":"Transparency","name":"flags_transparent","type":"boolean"},{"default":11.0,"first":6.0,"label":"Textures Size","last":13.0,"name":"size","type":"size"},{"control":"None","default":16.0,"label":"Parallax Steps","max":64.0,"min":2.0,"name":"iter","step":1.0,"type":"float"}],"preview_shader":"shader_type spatial;\nrender_mode blend_mix,cull_back,diffuse_burley,specular_schlick_ggx\n$if $(connected:opacity_tex) and $(param:flags_transparent)\n,depth_prepass_alpha\n$fi\n;\n\nuniform sampler2D texture_albedo : source_color; // $output(0)\nuniform sampler2D texture_emission : hint_default_black; // $output(2)\nuniform sampler2D texture_normal : hint_normal; // $output(3)\nuniform sampler2D texture_orm : hint_default_white; // $output(1)\nuniform sampler2D texture_parallax : source_color; // $output(5)\n\nuniform vec3 uv1_scale;\nuniform vec3 uv1_offset;\n\n$definitions\n\nvoid vertex() {\n\tUV=UV*uv1_scale.xy+uv1_offset.xy;\n}\n\nvoid fragment() {\n\tvec2 base_uv = UV;\n\tint texture_size = textureSize(texture_albedo, 0).x;\n\tif (texture_size < 256) {\n\t\tbase_uv = floor(float(texture_size)*base_uv+0.5)/float(texture_size);\n\t}\n\tvec3 parallax = vec3(0.0);\n$if $(connected:parallax_tex)\n\t{\n$begin_generate\n\t\tint p_iter = int($iter);\n$end_generate\n\t\tvec3 view_dir = inverse(mat3(TANGENT, -BINORMAL, NORMAL))*VIEW;\n\t\tfor (int j = 0; j < p_iter; j++) {\n\t\t\tfloat ratio = float(j) / float(p_iter);\n$begin_generate\n\t\t\tparallax += texture(texture_parallax, base_uv - mix(0.0, $offset_scale, ratio) * view_dir.xy).rgb * mix(1.0, 0.0, ratio);\n$end_generate\n\t\t}\n\t\tparallax /= float(p_iter);\n\t}\n$fi\n$begin_generate\n\tvec4 albedo_tex = texture(texture_albedo, base_uv);\n\tALBEDO = $albedo_color.rgb * mix(pow((albedo_tex + vec4(0.055))/vec4(1.055), vec4(2.4)), albedo_tex/vec4(12.92), lessThan(albedo_tex, vec4(0.04045))).rgb;\n\tALBEDO += parallax;\n\tvec4 orm_tex = texture(texture_orm, base_uv);\n\tMETALLIC = $metallic*orm_tex.b;\n\tROUGHNESS = $roughness*orm_tex.g;\n\tSPECULAR = 0.5;\n\tNORMAL_MAP = texture(texture_normal, base_uv).rgb;\n\tNORMAL_MAP_DEPTH = $normal;\n\tvec3 emission_tex = texture(texture_emission, base_uv).rgb;\n\tEMISSION = emission_tex*$emission_energy;\n\tAO = orm_tex.r;\n\tAO_LIGHT_AFFECT = $ao;\n$if $(connected:opacity_tex) and $(param:flags_transparent)\n\tALPHA = albedo_tex.a;\n\tALPHA_SCISSOR_THRESHOLD = 0.01;\n$fi\n$end_generate\n}\n","shortdesc":"Static PBR Material Parallax"},"type":"material_export"},{"name":"voronoi2","node_position":{"x":-1719.251953125,"y":152.463989257812},"parameters":{"intensity":1.0,"randomness":1.0,"scale_x":4.0,"scale_y":4.0,"stretch_x":1.0,"stretch_y":1.0},"seed_int":1427299328,"type":"voronoi2"},{"name":"tones_step","node_position":{"x":230.187362670898,"y":374.450897216797},"parameters":{"invert":true,"value":0.03,"width":0.0},"seed_int":0,"type":"tones_step"},{"name":"tones_step_2","node_position":{"x":355.264770507812,"y":930.019775390625},"parameters":{"invert":true,"value":0.0432,"width":0.08},"seed_int":0,"type":"tones_step"},{"name":"buffer_2","node_position":{"x":642.878540039062,"y":944.765441894531},"parameters":{"size":8.0},"seed_int":0,"type":"buffer","version":1},{"generic_size":1,"name":"warp","node_position":{"x":-1434.92846679688,"y":38.1130180358887},"parameters":{"amount":0.125,"eps":0.1,"mode":0.0},"seed_int":0,"type":"warp"},{"name":"fbm3","node_position":{"x":-1729.48181152344,"y":338.7939453125},"parameters":{"folds":0.0,"iterations":5.0,"noise":0.0,"offset":1.0,"persistence":0.5,"scale_x":2.0,"scale_y":2.0},"seed_int":0,"type":"fbm3"},{"generic_size":4,"name":"blend2","node_position":{"x":916.880554199219,"y":-485.966400146484},"parameters":{"amount1":1.0,"amount2":0.35,"amount3":0.58,"amount4":0.38,"blend_type1":12.0,"blend_type2":0.0,"blend_type3":0.0,"blend_type4":0.0},"seed_int":0,"type":"blend2"},{"name":"uniform","node_position":{"x":405.634216308594,"y":273.227844238281},"parameters":{"color":{"a":1.0,"b":1.0,"g":0.800369262695312,"r":0.65234375,"type":"Color"}},"seed_int":0,"type":"uniform"},{"generic_size":2,"name":"blend2_2","node_position":{"x":865.958618164062,"y":827.060729980469},"parameters":{"amount1":1.0,"amount2":0.5