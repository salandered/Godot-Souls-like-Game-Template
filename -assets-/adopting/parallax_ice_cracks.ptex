,"y":216.533493041992},"parameters":{"param0":10.0,"param1":3.0,"param2":40.0,"param3":0.0},"seed_int":0,"type":"multi_warp"},{"name":"math","node_position":{"x":-915.686828613281,"y":280.004058837891},"parameters":{"clamp":false,"default_in1":0.0,"default_in2":0.0,"op":0.0},"seed_int":0,"type":"math"},{"name":"fbm3_3","node_position":{"x":-1450.17895507812,"y":431.328979492188},"parameters":{"folds":0.0,"iterations":5.0,"noise":0.0,"offset":0.0,"persistence":0.45,"scale_x":8.0,"scale_y":8.0},"seed_int":0,"type":"fbm3"},{"name":"shader_2","node_position":{"x":-1199.37878417969,"y":432.429016113281},"parameters":{"clamp":true,"fromMax":1.0,"fromMin":0.09,"mode":0.0,"toMax":0.02431,"toMin":0.0,"value":1.0},"seed_int":0,"shader_model":{"code":"float $(name_uv)_clamp_false = $mode($value*$vmap($uv),$fromMin*$fmin_map($uv),$fromMax*$fmax_map($uv),$toMin*$tmin_map($uv),$toMax*$tmax_map($uv));\nfloat $(name_uv)_clamp_true = clamp($(name_uv)_clamp_false,$toMin,$toMax);","global":"float safe_divide(float a, float b)\n{\n  return (b != 0.0) ? a / b : 0.0;\n}\n\nfloat smootherstep(float edge0, float edge1, float x)\n{\n  x = clamp(safe_divide((x - edge0), (edge1 - edge0)), 0.0, 1.0);\n  return x * x * x * (x * (x * 6.0 - 15.0) + 10.0);\n}\n\nfloat smoothstep_map_range(float value, float fromMin, float fromMax, float toMin, float toMax){\n\tfloat result;  \n\tif (fromMax != fromMin) {\n\t    float factor = (fromMin > fromMax) ? 1.0 - smoothstep(fromMax, fromMin, value) :\n\t                                         smoothstep(fromMin, fromMax, value);\n\t    result = toMin + factor * (toMax - toMin);\n\t }\n\t else {\n\t    result = 0.0;\n\t }\n\t\treturn result;\n}\n\nfloat smootherstep_map_range(float value, float fromMin, float fromMax, float toMin, float toMax){\n\tfloat result;\n\tif (fromMax != fromMin) {\n\t\tfloat factor = (fromMin > fromMax) ? 1.0 - smootherstep(fromMax, fromMin, value) :\n\t                    smootherstep(fromMin, fromMax, value);\n\t\t\t\t\t\tresult = toMin + factor * (toMax - toMin);\n\t}\n\telse {\n\t\tresult = 0.0;\n\t}\n\treturn result;\n}\n\nfloat linear_map_range(float value, float fromMin, float fromMax, float toMin, float toMax){\n\tfloat result;\n\tif (fromMax != fromMin) {\n    \tresult = toMin + ((value - fromMin) / (fromMax - fromMin)) * (toMax - toMin);\n  \t}\n\telse\n\t{\n\t\tresult = 0.0;\n\t}\n\treturn result;\n}\n\n","inputs":[{"default":"uv.x","label":"2:","name":"vmap","shortdesc":"Value Map","type":"f"},{"default":"1.0","label":"3:","name":"fmin_map","shortdesc":"From Min Map","type":"f"},{"default":"1.0","label":"4:","name":"fmax_map","shortdesc":"From Max Map","type":"f"},{"default":"1.0","label":"5:","name":"tmin_map","shortdesc":"To Min Map","type":"f"},{"default":"1.0","label":"6:","name":"tmax_map","shortdesc":"To Max Map","type":"f"}],"instance":"","name":"Map Range","outputs":[{"f":"$(name_uv)_clamp_$clamp","shortdesc":"Result","type":"f"}],"parameters":[{"default":1.0,"label":"1:","name":"mode","type":"enum","values":[{"name":"Linear","value":"linear_map_range"},{"name":"Smooth Step","value":"smoothstep_map_range"},{"name":"Smoother Step","value":"smootherstep_map_range"}]},{"control":"None","default":0.0,"label":"Value","max":1.0,"min":0.0,"name":"value","step":0.001,"type":"float"},{"control":"None","default":0.0,"label":"From Min","max":1.0,"min":0.0,"name":"fromMin","step":0.001,"type":"float"},{"control":"None","default":1.0,"label":"From Max","max":1.0,"min":0.0,"name":"fromMax","step":0.001,"type":"float"},{"control":"None","default":0.0,"label":"To Min","max":1.0,"min":0.0,"name":"toMin","step":0.001,"type":"float"},{"control":"None","default":1.0,"label":"To Max","max":1.0,"min":0.0,"name":"toMax","step":0.001,"type":"float"},{"default":true,"label":"Clamp","name":"clamp","shortdesc":"Clamp range to [To Min, To Max]","type":"boolean"}],"shortdesc":"Linear interpolation from From Min and From Max values"},"type":"shader"},{"name":"voronoi2_2","node_position":{"x":-124.07815