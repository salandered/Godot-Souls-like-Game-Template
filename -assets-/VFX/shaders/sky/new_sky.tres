[gd_resource type="Sky" load_steps=5 format=3 uid="uid://bjxpm7vkr1f54"]

[sub_resource type="Shader" id="Shader_p2dh0"]
code = "shader_type sky;

uniform sampler2D clouds_sampler : filter_linear_mipmap;
uniform vec3 top_color : source_color = vec3(0.2, 0.4, 0.8);
uniform vec3 bottom_color : source_color = vec3(0.6, 0.8, 1.0);
uniform vec3 sun_scatter : source_color = vec3(1.0, 0.6, 0.3);

const float sun_radius = 0.08;

// --- PARAMETERS ---
uniform float star_strength : hint_range(0.0, 5.0, 0.1) = 0.0;
uniform float star_density : hint_range(0.001, 0.02, 0.001) = 0.002; 
uniform float cloud_speed : hint_range(0.0, 0.1, 0.001) = 0.005;

// NEW: Controls how much of the sky is covered by clouds.
// 0.3 = Very dense/overcast
// 0.8 = Very few clouds (Sunny)
uniform float cloud_coverage : hint_range(0.0, 1.0, 0.01) = 0.75; 
// ------------------

float random(vec2 uv) {
	return fract(sin(dot(uv.xy, vec2(12.9898,78.233))) * 43758.5453123);
}

void sky() {
	vec3 sky_gradient = mix(bottom_color.rgb, top_color.rgb, clamp(EYEDIR.y, 0.0, 1.0));
	
	float sun_position = distance(EYEDIR.xyz, LIGHT0_DIRECTION);
	float sun_mask_edge = smoothstep(sun_radius, sun_radius * 0.9, sun_position) * 0.2;
	float sun_mask = smoothstep(sun_radius * 0.7, sun_radius * 0.65, sun_position) * 0.8;
	float sun_intensity = (sun_mask_edge + sun_mask) * LIGHT0_ENERGY;
	
	float horizon_mask = 1.0 - abs(EYEDIR.y);
	vec3 sunset_color = sun_scatter * pow(horizon_mask, 5.0);
	
	vec3 final_color = sky_gradient + sunset_color; // + (sun_intensity * vec3(1.0));

	// --- STARS ---
	if(star_strength > 0.0 && EYEDIR.y > 0.0) {
		vec2 star_uv = vec2(atan(EYEDIR.z, EYEDIR.x), asin(EYEDIR.y));
		float noise_val = random(floor(star_uv * 400.0));
		
		float star_cutoff = 1.0 - star_density;
		float star_visibility = step(star_cutoff, noise_val); 
		
		float twinkle = sin(TIME * 2.0 + noise_val * 10.0);
		final_color += vec3(star_visibility * star_strength * (0.85 + 0.15 * twinkle));
	}

	// --- CLOUDS ---
	if (EYEDIR.y > 0.0) {
		vec2 cloud_uv = EYEDIR.xz / (EYEDIR.y + 0.1);
		float cloud_val = texture(clouds_sampler, cloud_uv * 0.1 + TIME * cloud_speed).r;
		
		// USE THE NEW PARAMETER HERE
		// We smoothstep from \"coverage\" to \"coverage + 0.1\" for a soft edge.
		float cloud_alpha = smoothstep(cloud_coverage, cloud_coverage + 0.1, cloud_val);
		
		float horizon_fade = smoothstep(0.0, 0.2, EYEDIR.y); 
		final_color = mix(final_color, vec3(1.0), cloud_alpha * horizon_fade);
	}

	COLOR = final_color;
}"

